# OpenAI
OPENAI_API_KEY=sk-...
# Model to use (default: gpt-4o). Options: gpt-4o, gpt-4.1, gpt-4o-mini
# OPENAI_MODEL=gpt-4o

# X / Twitter (OAuth 1.0a — from developer.twitter.com)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional: HTTP health check port (default: 8080)
# PORT=8080

# Optional: directory where tweet_bot.log is written (default: logs/)
# LOG_DIR=/app/logs
